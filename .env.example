# =============================================================================
# JANUS — Sci-Fi Campaign Console
# Copy this file to .env and fill in your values before first run.
# =============================================================================

# -----------------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------------

# Django secret key — generate one with: openssl rand -hex 32
SECRET_KEY=

# GM admin account created automatically on first container start
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=
DJANGO_SUPERUSER_EMAIL=admin@localhost

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------

# Comma-separated hostnames/IPs that Django will accept requests from.
# Add your server's LAN IP so players on the network can connect.
# Example: ALLOWED_HOSTS=192.168.1.100,localhost,127.0.0.1
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Optional features
# -----------------------------------------------------------------------------

# Anthropic API key — required for JANUS AI terminal features
ANTHROPIC_API_KEY=

# Set to True only for local troubleshooting — never in normal use
DEBUG=False
